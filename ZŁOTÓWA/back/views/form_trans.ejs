<head>
    <meta charset="UTF-8">
    <title>Logowanie</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
<div class="login-card">
<h1>Stwórz nowy pokój</h1>

<form action="/new_transaction/<%= room.R_ID_Room %>" method="POST">
    <input type="text" name="borrower" placeholder="user" required><br>
    <input type="number" name="amount" placeholder="kwota" required><br>
    <input type="text" name="desc" placeholder="Opis" required><br>
    <button type="submit">Dodaj transakcje</button>
</form>
</div>
</body>